#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="$ROOT/target/debug/tep"
if [[ ! -x "$BIN" ]]; then
  echo "tep launcher error: built binary not found at $BIN" >&2
  echo "run: cd $ROOT && source \"$HOME/.cargo/env\" && cargo build" >&2
  exit 1
fi
exec "$BIN" "$@"
